# Storage (Postgres required)
# For multi-DB tenant isolation, point at a Postgres ROLE that has CREATEDB
# privilege and use a maintenance database (e.g. `postgres`) so the registry
# can auto-create per-tenant DBs. For production via the sql_proxy sidecar,
# use https://<pg_cvm_id>-8080.app.phala.network instead.
HIVEMIND_DATABASE_URL=postgresql://hivemind:dev@localhost:5432/postgres
HIVEMIND_HOST=127.0.0.1
HIVEMIND_PORT=8100

# ── Multi-tenant control plane (required) ──
# HIVEMIND_ADMIN_KEY gates /v1/admin/tenants so you (the operator) can mint
# per-tenant API keys. Required for any non-local bind. By design the admin
# can create/delete tenants but cannot read tenant data (each tenant gets
# its own Postgres database). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
HIVEMIND_ADMIN_KEY=
# For HTTP sql_proxy deploys (Phala split CVM): must match
# SQL_PROXY_ADMIN_KEY on the proxy sidecar. For direct-psycopg deploys
# (local dev, single-process), leave blank — CREATE DATABASE goes straight
# to Postgres using HIVEMIND_DATABASE_URL credentials.
HIVEMIND_SQL_PROXY_ADMIN_KEY=
# Control DB name (metadata: tenant IDs, hashed keys, db_name mapping).
# Auto-created on first boot.
HIVEMIND_CONTROL_DATABASE=hivemind_control
# LRU cache size for per-tenant Hivemind instances (each ≈ 1 DB conn).
HIVEMIND_TENANT_CACHE_SIZE=32
# Comma-separated origins for browser CORS. Empty = no CORS headers.
HIVEMIND_CORS_ALLOW_ORIGINS=

# LLM (for bridge proxy — all LLM calls go through Docker agent containers).
# Default is OpenRouter + GLM-5. To use Anthropic directly, set:
#   HIVEMIND_LLM_BASE_URL=https://api.anthropic.com
#   HIVEMIND_LLM_MODEL=claude-sonnet-4-5
# (The bridge auto-injects ANTHROPIC_BASE_URL inside agent containers, so
# OpenAI- and Anthropic-format SDKs both work without further config.)
HIVEMIND_LLM_API_KEY=
HIVEMIND_LLM_BASE_URL=https://openrouter.ai/api/v1
HIVEMIND_LLM_MODEL=z-ai/glm-5
HIVEMIND_LLM_TIMEOUT_SECONDS=45

# Docker sandbox
HIVEMIND_BRIDGE_HOST=0.0.0.0
HIVEMIND_DOCKER_HOST=
HIVEMIND_DOCKER_NETWORK=hivemind-sandbox
HIVEMIND_DOCKER_NETWORK_INTERNAL=true
HIVEMIND_DOCKER_BUILD_NETWORK=none
HIVEMIND_DOCKER_BUILD_TIMEOUT_SECONDS=600
HIVEMIND_DOCKER_BUILD_MEMORY_MB=1024
HIVEMIND_DOCKER_BUILD_CPU_SHARES=512
# Linux-only hardening: install per-container DOCKER-USER rules to allow only bridge IP:port.
# Ignored on macOS/Windows.
HIVEMIND_ENFORCE_BRIDGE_ONLY_EGRESS=true
HIVEMIND_ENFORCE_BRIDGE_ONLY_EGRESS_FAIL_CLOSED=true
HIVEMIND_CONTAINER_MEMORY_MB=256
HIVEMIND_CONTAINER_CPU_QUOTA=1.0
HIVEMIND_CONTAINER_PIDS_LIMIT=256
HIVEMIND_CONTAINER_USER=1000:1000
HIVEMIND_CONTAINER_READ_ONLY_FS=true
HIVEMIND_CONTAINER_DROP_ALL_CAPS=true
HIVEMIND_CONTAINER_NO_NEW_PRIVILEGES=true
HIVEMIND_MAX_LLM_CALLS=50
HIVEMIND_MAX_TOKENS=200000
HIVEMIND_AGENT_TIMEOUT=300

# Default agents
# Stable IDs can be autoloaded from Docker images at startup.
# Build local defaults first:
#   docker build -t hivemind-default-index:local agents/default-index
#   docker build -t hivemind-default-query:local agents/default-query
#   docker build -t hivemind-default-scope:local agents/default-scope
#   docker build -t hivemind-default-mediator:local agents/default-mediator
HIVEMIND_AUTOLOAD_DEFAULT_AGENTS=true
HIVEMIND_DEFAULT_INDEX_AGENT=default-index
HIVEMIND_DEFAULT_QUERY_AGENT=default-query
HIVEMIND_DEFAULT_SCOPE_AGENT=default-scope
HIVEMIND_DEFAULT_MEDIATOR_AGENT=default-mediator
HIVEMIND_DEFAULT_INDEX_IMAGE=hivemind-default-index:local
HIVEMIND_DEFAULT_QUERY_IMAGE=hivemind-default-query:local
HIVEMIND_DEFAULT_SCOPE_IMAGE=hivemind-default-scope:local
HIVEMIND_DEFAULT_MEDIATOR_IMAGE=hivemind-default-mediator:local

# ── Cloudflare DNS (Phala prod9 deploy only) ──
# Required only when redeploying the Phala CVM via deploy/phala/deploy.sh
# (not for local dev). The dstack-ingress sidecar uses this to:
#  1. Run ACME DNS-01 challenges on hivemind.teleport.computer
#  2. Maintain the _dstack-app-address.<domain> TXT record routing
#  3. Pin a CAA record to Let's Encrypt
#
# Token scope: Zone.DNS:Edit on the teleport.computer zone. Mint at
# https://dash.cloudflare.com/profile/api-tokens (Custom token, single
# zone, single permission). The token never leaves the enclave at
# runtime — it's sealed via `phala deploy -e` into the encrypted env
# channel.
#
# Override host: rename the default friendly domain by setting
# HIVEMIND_FRIENDLY_DOMAIN as well (otherwise defaults to
# hivemind.teleport.computer in deploy/phala/docker-compose.core.yaml).
CLOUDFLARE_API_TOKEN=
HIVEMIND_FRIENDLY_DOMAIN=hivemind.teleport.computer
CERTBOT_EMAIL=
