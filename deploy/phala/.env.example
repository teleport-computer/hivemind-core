# deploy/phala/.env.example — canonical template for the Phala CVM
# deploy. Copy to `deploy/phala/.env` and fill in values:
#
#     cp deploy/phala/.env.example deploy/phala/.env
#     vi deploy/phala/.env
#     chmod 600 deploy/phala/.env
#
# This single file feeds BOTH the postgres CVM (hivemind-pg) and the
# core CVM (hivemind-core). `deploy/phala/deploy.sh` and every GitHub
# Actions workflow that talks to the relay (deploy.yml, smoke-test.yml,
# migrate-pg-data.yml, admin-reset-tenant-key.yml, …) source this file
# and only this file. There are no `.env.core` / `.env.postgres`
# variants — keep one source of truth.
#
# Values come from a mix of:
#   * One-shot generation locally:
#       python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
#     for HIVEMIND_ADMIN_KEY, SQL_PROXY_KEY, SQL_PROXY_ADMIN_KEY, DB_PASS.
#   * External services: HIVEMIND_LLM_API_KEY (OpenRouter or Anthropic),
#     R2_* (Cloudflare R2 for backups), CLOUDFLARE_API_TOKEN
#     (DNS-01 challenge for the friendly hostname).
#   * Resolved from the deployed CVM: HIVEMIND_DATABASE_URL is the
#     gateway URL of the postgres CVM's port 8080 — set after the pg
#     CVM is up. deploy.yml has a `database_url_override` input that
#     rewrites it on the relay during a pg-cluster cutover.

# ── Postgres CVM ────────────────────────────────────────────────────
# Used by the postgres CVM compose (docker-compose.postgres.yaml).
# DB_PASS is the password for the `hivemind` Postgres role.
# SQL_PROXY_KEY is the data-plane key (X-Proxy-Key header) for the
# sql_proxy sidecar — every cross-CVM SQL call carries it.
# SQL_PROXY_ADMIN_KEY is the control-plane key for proxy admin ops
# (CREATE DATABASE / ROLE).
DB_PASS=
SQL_PROXY_KEY=
SQL_PROXY_ADMIN_KEY=
# Guard SELECT responses before a scope/query agent can OOM the postgres CVM.
SQL_PROXY_MAX_RESULT_ROWS=10000
SQL_PROXY_MAX_RESULT_BYTES=16777216

# ── Core CVM → Postgres CVM (cross-CVM link) ───────────────────────
# Phala-gateway HTTPS URL of the postgres CVM's port 8080.
# Pattern: https://<pg_app_id>-8080.<gateway_base>.phala.network
# Look up the live URL with: phala cvms get --cvm-id hivemind-pg --json
HIVEMIND_DATABASE_URL=

# ── Core CVM — hivemind-core config ────────────────────────────────
# HIVEMIND_ADMIN_KEY gates /v1/admin/* (tenant provisioning). Generate
# with secrets.token_urlsafe(32). Ship a `hmk_…` per-tenant key to
# users — they cannot read the admin key.
HIVEMIND_ADMIN_KEY=
# Comma-separated origins for browser CORS. Empty = no CORS headers.
HIVEMIND_CORS_ALLOW_ORIGINS=

# HIVEMIND_PINNING_GATEWAY is intentionally OMITTED here — leave unset.
# `deploy/phala/deploy.sh` auto-syncs it on every deploy by reading the
# CVM's actual `gateway.base_domain` and rewriting this `.env` on the
# relay. Hand-setting it is safe but unnecessary; a stale value will be
# overwritten on next deploy. (Real incident 2026-04-26: a hand-set
# prod5 override here pointed the bundle's `tls.pinning_url` at the
# wrong cluster after a prod9 migration. The auto-sync prevents recurrence.)

# ── LLM (bridge proxy → all agent containers) ──────────────────────
# Default is OpenRouter + GLM-5. Per-role overrides below let you pin a
# specific model for each agent role; empty falls back to HIVEMIND_LLM_MODEL.
#
# For Anthropic direct, set:
#   HIVEMIND_LLM_BASE_URL=https://api.anthropic.com
#   HIVEMIND_LLM_MODEL=claude-sonnet-4-5
HIVEMIND_LLM_API_KEY=
HIVEMIND_LLM_BASE_URL=https://openrouter.ai/api/v1
HIVEMIND_LLM_MODEL=z-ai/glm-5

# Per-role overrides. Use these only when a room needs a stronger or more
# conservative model for a specific stage.
# HIVEMIND_SCOPE_MODEL=
# HIVEMIND_QUERY_MODEL=
# HIVEMIND_MEDIATOR_MODEL=
# HIVEMIND_INDEX_MODEL=

# ── Billing ────────────────────────────────────────────────────────
# false: meter usage and charge known payer accounts, but do not reject
# insufficient or missing credit. true: query-token room runs must include a
# payer hmk_ credential and enough prepaid credit for the requested budget.
HIVEMIND_BILLING_ENFORCE_CREDITS=true
# Public signup for users to create their own hmk_ tenant key. New users start
# with $0 balance and can redeem admin-minted credit codes later.
HIVEMIND_SELF_SERVE_SIGNUP_ENABLED=true

# ── Sandbox limits ─────────────────────────────────────────────────
# Uploaded agent builds run with no network plus resource caps. Runtime
# containers run as numeric uid/gid 1000 by default.
# HIVEMIND_DOCKER_BUILD_NETWORK=none
# HIVEMIND_DOCKER_BUILD_TIMEOUT_SECONDS=600
# HIVEMIND_DOCKER_BUILD_MEMORY_MB=1024
# HIVEMIND_DOCKER_BUILD_CPU_SHARES=512
# HIVEMIND_CONTAINER_USER=1000:1000

# ── R2 (WAL-G backup storage for postgres CVM) ─────────────────────
# These ride into the postgres CVM only. The core CVM doesn't use R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
WALG_S3_PREFIX=s3://<bucket>/wal-g
# Optional — omit for unencrypted backups. 64 hex chars if set.
# WALG_LIBSODIUM_KEY=

# ── Default agent images (optional) ────────────────────────────────
# The production core image bundles repo-owned Docker contexts under
# /app/agents and can build the local Hermes defaults below on first boot.
# Claude-Code defaults are still operator-provided: pre-push them to GHCR
# and set these, or leave commented and use `hivemind run` to upload after
# deploy. Set HIVEMIND_AUTOLOAD_DEFAULT_AGENTS=true to register configured
# defaults.
# HIVEMIND_AUTOLOAD_DEFAULT_AGENTS=true
# HIVEMIND_BUNDLED_AGENTS_DIR=/app/agents
# HIVEMIND_DEFAULT_INDEX_IMAGE=ghcr.io/teleport-computer/hivemind-default-index:latest
# HIVEMIND_DEFAULT_QUERY_IMAGE=ghcr.io/teleport-computer/hivemind-default-query:latest
# HIVEMIND_DEFAULT_SCOPE_IMAGE=ghcr.io/teleport-computer/hivemind-default-scope:latest
# HIVEMIND_DEFAULT_MEDIATOR_IMAGE=ghcr.io/teleport-computer/hivemind-default-mediator:latest

# Hermes-harness defaults (NousResearch/hermes-agent).
# HIVEMIND_DEFAULT_INDEX_AGENT=default-index-hermes
# HIVEMIND_DEFAULT_QUERY_AGENT=default-query-hermes
# HIVEMIND_DEFAULT_SCOPE_AGENT=default-scope-hermes
# HIVEMIND_DEFAULT_MEDIATOR_AGENT=default-mediator-hermes
# HIVEMIND_DEFAULT_INDEX_HERMES_IMAGE=hivemind-default-index-hermes:latest
# HIVEMIND_DEFAULT_QUERY_HERMES_IMAGE=hivemind-default-query-hermes:latest
# HIVEMIND_DEFAULT_SCOPE_HERMES_IMAGE=hivemind-default-scope-hermes:latest
# HIVEMIND_DEFAULT_MEDIATOR_HERMES_IMAGE=hivemind-default-mediator-hermes:latest

# ── Cloudflare DNS (REQUIRED for the friendly hivemind-core URL) ───
# The dstack-ingress sidecar uses this to:
#   1. Run ACME DNS-01 on hivemind.teleport.computer
#   2. Maintain the _dstack-app-address.<domain> TXT record
#   3. Pin a CAA record to Let's Encrypt
# Token scope: Zone.DNS:Edit on the teleport.computer zone.
# Compose-required (`${CLOUDFLARE_API_TOKEN:?…}`) — deploy fails if empty.
CLOUDFLARE_API_TOKEN=
# Friendly hostname + ACME contact email default to teleport values.
# Override here if you're forking the deploy onto a different domain.
# HIVEMIND_FRIENDLY_DOMAIN=hivemind.teleport.computer
# CERTBOT_EMAIL=
