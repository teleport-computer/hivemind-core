# deploy/.env.example — Copy to deploy/.env and fill in values.
# .env is gitignored and will NOT be committed.

# --- Database ---
DB_PASS=changeme_use_a_strong_password

# --- Hivemind API ---
HIVEMIND_API_KEY=your-api-key
HIVEMIND_LLM_API_KEY=your-llm-api-key
# HIVEMIND_LLM_BASE_URL=https://openrouter.ai/api/v1
# HIVEMIND_LLM_MODEL=anthropic/claude-sonnet-4.5

# --- Cloudflare R2 (shared by WAL-G backup + query agent result uploads) ---
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-r2-bucket-name

# WAL-G S3 prefix — format: s3://bucket-name/optional-path
WALG_S3_PREFIX=s3://${R2_BUCKET}/wal-g

# R2 endpoint (S3-compatible) — note: no bucket name in the URL
R2_ENDPOINT=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# WAL-G encryption key (64 hex chars, optional — omit for unencrypted backups)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# WALG_LIBSODIUM_KEY=

# --- SQL Proxy (Phala split deploy: postgres CVM ↔ core CVM) ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# SQL_PROXY_KEY=your-proxy-shared-secret
# HIVEMIND_SQL_PROXY_KEY=same-as-above
# HIVEMIND_DATABASE_URL=https://<pg_cvm_id>-8080.app.phala.network

# --- Phala Cloud (production TEE deployment) ---
# Only needed when HIVEMIND_SANDBOX_BACKEND=phala
# HIVEMIND_SANDBOX_BACKEND=phala
# HIVEMIND_PHALA_API_KEY=phak_your_api_key
# HIVEMIND_PHALA_TEEPOD_ID=3
# HIVEMIND_PHALA_VCPU=2
# HIVEMIND_PHALA_MEMORY=2048
# HIVEMIND_PHALA_DISK_SIZE=20
# HIVEMIND_PHALA_PUBLIC_URL=https://<cvm_id>-8100.app.phala.network

# Persistent agent CVM URLs (scope/index/mediator run as long-lived services)
# HIVEMIND_PHALA_SCOPE_URL=https://<scope_cvm_id>-8080.app.phala.network
# HIVEMIND_PHALA_INDEX_URL=https://<index_cvm_id>-8080.app.phala.network
# HIVEMIND_PHALA_MEDIATOR_URL=https://<mediator_cvm_id>-8080.app.phala.network

# --- GHCR (for pushing images) ---
# GHCR_TOKEN=ghp_your_token
